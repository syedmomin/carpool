NODE_ENV=development
PORT=5000

# Database — replace with your Supabase / local PostgreSQL URL
DATABASE_URL="postgresql://postgres:password@localhost:5432/safarishare_dev?schema=carpool"

# JWT
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:3000

# Email (optional)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@safarishare.pk
