generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum VehicleType {
  CAR
  VAN
  HIACE
  COASTER
  BUS
  PICKUP
}

enum NotificationType {
  BOOKING
  RIDE
  REMINDER
  NEW_RIDE
  SYSTEM
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  name         String
  email        String    @unique
  phone        String    @unique
  password     String
  role         UserRole  @default(PASSENGER)
  avatar       String?
  city         String?
  isVerified   Boolean   @default(false)
  isActive     Boolean   @default(true)
  fcmToken     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?

  ridesAsDriver    Ride[]         @relation("DriverRides")
  bookings         Booking[]
  notifications    Notification[]
  reviews          Review[]       @relation("ReviewedBy")
  reviewsReceived  Review[]       @relation("ReviewsForDriver")
  vehicles         Vehicle[]
  scheduleAlerts   ScheduleAlert[]
  verification     UserVerification?

  @@map("users")
}

model Vehicle {
  id          String      @id @default(cuid())
  driverId    String
  type        VehicleType
  brand       String
  model       String?
  color       String?
  plateNumber String      @unique
  totalSeats  Int
  ac          Boolean     @default(false)
  wifi        Boolean     @default(false)
  music       Boolean     @default(false)
  usbCharging Boolean     @default(false)
  waterCooler Boolean     @default(false)
  blanket     Boolean     @default(false)
  firstAid    Boolean     @default(false)
  luggageRack Boolean     @default(false)
  images      String[]
  isActive    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   String?
  updatedBy   String?

  driver      User        @relation(fields: [driverId], references: [id], onDelete: Cascade)
  rides       Ride[]

  @@map("vehicles")
}

model Ride {
  id            String     @id @default(cuid())
  driverId      String
  vehicleId     String
  fromCity      String
  toCity        String
  fromLat       Float?
  fromLng       Float?
  toLat         Float?
  toLng         Float?
  isMultiStop   Boolean    @default(false)
  stops         Json?
  date          String
  departureTime String
  arrivalTime   String?
  pricePerSeat  Int
  totalSeats    Int
  bookedSeats   Int        @default(0)
  pickupPoint   String?
  dropPoint     String?
  description   String?
  amenities     String[]
  status        RideStatus @default(ACTIVE)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     String?
  updatedBy     String?

  driver        User       @relation("DriverRides", fields: [driverId], references: [id])
  vehicle       Vehicle    @relation(fields: [vehicleId], references: [id])
  bookings      Booking[]

  @@index([fromCity, toCity, date, status])
  @@map("rides")
}

model Booking {
  id           String        @id @default(cuid())
  rideId       String
  passengerId  String
  seats        Int
  totalAmount  Int
  boardingCity String?
  exitCity     String?
  boardingOrder Int?
  exitOrder    Int?
  cancellationReason String?
  status       BookingStatus @default(CONFIRMED)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  createdBy    String?
  updatedBy    String?

  ride         Ride          @relation(fields: [rideId], references: [id])
  passenger    User          @relation(fields: [passengerId], references: [id])

  @@map("bookings")
}

model Review {
  id         String   @id @default(cuid())
  driverId   String
  reviewerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?

  driver     User     @relation("ReviewsForDriver", fields: [driverId],   references: [id])
  reviewer   User     @relation("ReviewedBy",       fields: [reviewerId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  rideId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  createdBy String?
  updatedBy String?

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model ScheduleAlert {
  id          String   @id @default(cuid())
  passengerId String
  fromCity    String
  toCity      String
  date        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?

  passenger   User     @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  @@map("schedule_alerts")
}

model UserVerification {
  id             String             @id @default(cuid())
  userId         String             @unique
  cnicNumber     String?
  cnicFront      String?
  cnicBack       String?
  cnicStatus     VerificationStatus @default(PENDING)
  licenceImage   String?
  licenceStatus  VerificationStatus @default(PENDING)
  rejectedReason String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?
  updatedBy      String?

  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_verifications")
}
