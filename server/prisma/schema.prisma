generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  name             String
  email            String            @unique
  phone            String            @unique
  password         String
  role             UserRole          @default(PASSENGER)
  avatar           String?
  city             String?
  isVerified       Boolean           @default(false)
  isActive         Boolean           @default(true)
  fcmToken         String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  createdBy        String?
  updatedBy        String?
  tokenVersion     Int               @default(0)
  bookings         Booking[]
  sentMessages     ChatMessage[]
  notifications    Notification[]
  reviewsReceived  Review[]          @relation("ReviewsReceived")
  reviews          Review[]          @relation("ReviewedBy")
  rideBids         RideBid[]         @relation("DriverBids")
  ridesAsDriver    Ride[]            @relation("DriverRides")
  scheduleAlerts   ScheduleAlert[]
  scheduleRequests ScheduleRequest[]
  verification     UserVerification?
  vehicles         Vehicle[]

  @@map("users")
}

model Vehicle {
  id          String      @id @default(cuid())
  driverId    String
  type        VehicleType
  brand       String
  model       String?
  color       String?
  plateNumber String      @unique
  totalSeats  Int
  ac          Boolean     @default(false)
  wifi        Boolean     @default(false)
  music       Boolean     @default(false)
  usbCharging Boolean     @default(false)
  waterCooler Boolean     @default(false)
  blanket     Boolean     @default(false)
  firstAid    Boolean     @default(false)
  luggageRack Boolean     @default(false)
  images      String[]
  isActive    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  createdBy   String?
  updatedBy   String?
  rideBids    RideBid[]
  rides       Ride[]
  driver      User        @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@map("vehicles")
}

model Ride {
  id            String         @id @default(cuid())
  driverId      String
  vehicleId     String
  fromCity      String
  toCity        String
  fromLat       Float?
  fromLng       Float?
  toLat         Float?
  toLng         Float?
  isMultiStop   Boolean        @default(false)
  stops         Json?
  date          String
  departureTime String
  arrivalTime   String?
  pricePerSeat  Int
  totalSeats    Int
  bookedSeats   Int            @default(0)
  pickupPoint   String?
  dropPoint     String?
  description   String?
  amenities     String[]
  status        RideStatus     @default(ACTIVE)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  createdBy     String?
  updatedBy     String?
  bookings      Booking[]
  reviews       Review[]
  locations     RideLocation[]
  route         RideRoute?
  driver        User           @relation("DriverRides", fields: [driverId], references: [id])
  vehicle       Vehicle        @relation(fields: [vehicleId], references: [id])

  @@index([fromCity, toCity, date, status])
  @@map("rides")
}

model Booking {
  id                 String        @id @default(cuid())
  rideId             String
  passengerId        String
  seats              Int
  totalAmount        Int
  boardingCity       String?
  exitCity           String?
  boardingOrder      Int?
  exitOrder          Int?
  cancellationReason String?
  status             BookingStatus @default(PENDING)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  createdBy          String?
  updatedBy          String?
  passenger          User          @relation(fields: [passengerId], references: [id])
  ride               Ride          @relation(fields: [rideId], references: [id])
  chatMessages       ChatMessage[]

  @@map("bookings")
}

model Review {
  id         String   @id @default(cuid())
  rideId     String?
  reviewerId String
  revieweeId String
  targetRole UserRole @default(DRIVER)
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  updatedBy  String?
  reviewee   User     @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  reviewer   User     @relation("ReviewedBy", fields: [reviewerId], references: [id])
  ride       Ride?    @relation(fields: [rideId], references: [id])

  @@map("reviews")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(SYSTEM)
  rideId    String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  createdBy String?
  updatedBy String?
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}

model ScheduleAlert {
  id          String   @id @default(cuid())
  passengerId String
  fromCity    String
  toCity      String
  date        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  updatedBy   String?
  passenger   User     @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  @@map("schedule_alerts")
}

model UserVerification {
  id             String             @id @default(cuid())
  userId         String             @unique
  cnicNumber     String?
  cnicFront      String?
  cnicBack       String?
  cnicStatus     VerificationStatus @default(PENDING)
  licenceImage   String?
  licenceStatus  VerificationStatus @default(PENDING)
  rejectedReason String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  createdBy      String?
  updatedBy      String?
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_verifications")
}

model RideRoute {
  id        String   @id @default(cuid())
  rideId    String   @unique
  polyline  String
  distance  Float
  duration  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@map("ride_routes")
}

model RideLocation {
  id        String   @id @default(cuid())
  rideId    String
  latitude  Float
  longitude Float
  speed     Float?
  heading   Float?
  timestamp DateTime @default(now())
  ride      Ride     @relation(fields: [rideId], references: [id], onDelete: Cascade)

  @@index([rideId, timestamp])
  @@map("ride_locations")
}

model ScheduleRequest {
  id            String                @id @default(cuid())
  passengerId   String
  fromCity      String
  toCity        String
  date          String
  departureTime String                @default("00:00")
  seats         Int                   @default(1)
  note          String?
  status      ScheduleRequestStatus @default(OPEN)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  createdBy   String?
  updatedBy   String?
  bids        RideBid[]
  passenger   User                  @relation(fields: [passengerId], references: [id], onDelete: Cascade)

  @@index([status, date])
  @@map("schedule_requests")
}

model RideBid {
  id                String          @id @default(cuid())
  scheduleRequestId String
  driverId          String
  vehicleId         String?
  pricePerSeat      Int
  note              String?
  status            BidStatus       @default(PENDING)
  rideId            String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  createdBy         String?
  updatedBy         String?
  departureTime     String          @default("00:00")
  driver            User            @relation("DriverBids", fields: [driverId], references: [id])
  scheduleRequest   ScheduleRequest @relation(fields: [scheduleRequestId], references: [id], onDelete: Cascade)
  vehicle           Vehicle?        @relation(fields: [vehicleId], references: [id])

  @@unique([scheduleRequestId, driverId])
  @@index([scheduleRequestId, status])
  @@map("ride_bids")
}

model ChatMessage {
  id        String    @id @default(cuid())
  bookingId String
  senderId  String
  content   String
  readAt    DateTime?
  createdAt DateTime  @default(now())
  booking   Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender    User      @relation(senderId, references: [id])
}

enum UserRole {
  PASSENGER
  DRIVER
  ADMIN
}

enum RideStatus {
  ACTIVE
  IN_PROGRESS
  COMPLETED
  CANCELLED
  EXPIRED
}

enum ScheduleRequestStatus {
  OPEN
  ACCEPTED
  EXPIRED
  CANCELLED
}

enum BidStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
  COMPLETED
}

enum VehicleType {
  CAR
  VAN
  HIACE
  COASTER
  BUS
  PICKUP
}

enum NotificationType {
  BOOKING
  RIDE
  REMINDER
  NEW_RIDE
  SYSTEM
  RIDE_CANCELLED
  RIDE_EXPIRED
  SCHEDULE_REQUEST
  RIDE_BID
  BID_ACCEPTED
  BID_REJECTED
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}
